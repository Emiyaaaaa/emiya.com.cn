---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Devider from "../../components/Devider.astro";
import Time from "../../components/Time.astro";
import {
	getPostExcerpt,
	getSortedPosts,
	getPostSlug,
	toISO
} from "../../lib/posts";
import { SITE_AUTHOR } from "../../consts";

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	return posts.map((post) => ({
		params: { slug: getPostSlug(post) }
	}));
}

const slug = Astro.params.slug!;
const posts = await getSortedPosts();
const entry = posts.find((p) => getPostSlug(p) === slug);

if (!entry) {
	return Astro.redirect("/404");
}

const { Content } = await render(entry);
const { title, date, tags, description, updatedAt } = entry.data;

const excerpt = description?.trim() || getPostExcerpt(entry.body ?? "", 140);

if (!Astro.site) {
	throw new Error("Missing `site` in astro.config.mjs");
}

const siteUrl = Astro.site.origin;
const publishedTime = toISO(date);
const modifiedTime = toISO(updatedAt) ?? publishedTime;
const canonicalUrl = new URL(`/blog/${slug}`, siteUrl).toString();

const currentTags = new Set(tags?.map((t) => t.toLowerCase()));
const relatedPosts =
	currentTags.size > 0
		? posts
				.filter(
					(p) =>
						getPostSlug(p) !== slug &&
						p.data.tags?.some((t) => currentTags.has(t.toLowerCase()))
				)
				.slice(0, 4)
		: [];

const articleJsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description: excerpt,
	datePublished: publishedTime,
	dateModified: modifiedTime,
	inLanguage: "zh-CN",
	keywords: tags?.join(", "),
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalUrl
	},
	url: canonicalUrl,
	author: {
		"@type": "Person",
		name: SITE_AUTHOR.name,
		url: siteUrl
	},
	publisher: {
		"@type": "Person",
		name: SITE_AUTHOR.name,
		url: siteUrl
	}
};

const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "首页",
			item: siteUrl
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "博客",
			item: new URL("/blog", siteUrl).toString()
		},
		{
			"@type": "ListItem",
			position: 3,
			name: title,
			item: canonicalUrl
		}
	]
};
---

<Layout
	title={title}
	description={excerpt}
	canonical={`/blog/${slug}`}
	keywords={tags && tags.length > 0 ? tags : undefined}
	ogType="article"
	ogTitle={title}
	ogDescription={excerpt}
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	tags={tags}
	twitterTitle={title}
	twitterDescription={excerpt}
	jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
	<article class="post px-5 pb-6 pt-3">
		<header class="m-1 w-full">
			<h1 class="m-0 text-3xl font-bold leading-snug">
				<span>{title}</span>
			</h1>
			<div
				class="ml-1 mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 opacity-70"
			>
				<Time format="MON DD · YYYY" date={date} />
			</div>
		</header>
		<Devider class="my-4" />
		<div class="markdown w-fill mt-4 flex flex-col px-[2%] py-2">
			<Content />
		</div>
		{
			relatedPosts.length > 0 && (
				<aside class="mt-10 border-t border-color-font/10 pt-6">
					<h2 class="text-lg font-bold">相关文章</h2>
					<ul class="mt-3 space-y-2 list-disc pl-5">
						{relatedPosts.map((p) => (
							<li>
								<a
									href={`/blog/${getPostSlug(p)}`}
									class="opacity-80 hover:opacity-100"
								>
									{p.data.title}
								</a>
							</li>
						))}
					</ul>
				</aside>
			)
		}
		<footer class="mt-10 text-sm opacity-60">
			转载请注明出处：
			<a href={canonicalUrl}>{canonicalUrl}</a> · 作者 {SITE_AUTHOR.name}
		</footer>
	</article>
</Layout>
