---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Time from "../../components/Time.astro";
import {
	getPostExcerpt,
	getSortedPosts,
	getPostSlug,
	toISO
} from "../../lib/posts";
import { SITE_AUTHOR } from "../../consts";

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	return posts.map((post) => ({
		params: { slug: getPostSlug(post) }
	}));
}

const slug = Astro.params.slug!;
const posts = await getSortedPosts();
const entry = posts.find((p) => getPostSlug(p) === slug);

if (!entry) {
	return Astro.redirect("/404");
}

const { Content } = await render(entry);
const { title, date, description, updatedAt } = entry.data;

const excerpt = description?.trim() || getPostExcerpt(entry.body ?? "", 140);

if (!Astro.site) {
	throw new Error("Missing `site` in astro.config.mjs");
}

const siteUrl = Astro.site.origin;
const githubEditUrl = `https://github.com/Emiyaaaaa/emiya.com.cn/blob/main/src/content/posts/${entry.id}.mdx`;
const publishedTime = toISO(date);
const modifiedTime = toISO(updatedAt) ?? publishedTime;
const canonicalUrl = new URL(`/posts/${slug}`, siteUrl).toString();

const articleJsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description: excerpt,
	datePublished: publishedTime,
	dateModified: modifiedTime,
	inLanguage: "zh-CN",
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalUrl
	},
	url: canonicalUrl,
	author: {
		"@type": "Person",
		name: SITE_AUTHOR.name,
		url: siteUrl
	},
	publisher: {
		"@type": "Person",
		name: SITE_AUTHOR.name,
		url: siteUrl
	}
};

const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "首页",
			item: siteUrl
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "博客",
			item: new URL("/posts", siteUrl).toString()
		},
		{
			"@type": "ListItem",
			position: 3,
			name: title,
			item: canonicalUrl
		}
	]
};
---

<Layout
	title={title}
	description={excerpt}
	canonical={`/posts/${slug}`}
	ogType="article"
	ogTitle={title}
	ogDescription={excerpt}
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	twitterTitle={title}
	twitterDescription={excerpt}
	jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
	<div class="max-w-[65ch] mx-auto px-4 py-10 pb-5">
		<article class="post font-mono flex flex-col flex-1 px-5 pb-6 pt-3">
			<header class="m-1 w-full">
				<h1 class="m-0 text-xl font-bold leading-snug">
					<span>{title}</span>
				</h1>
				<div
					class="ml-1 mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 opacity-70"
				>
					<Time format="YYYY-MM-DD" date={date} />
				</div>
			</header>
			<div class="my-4 h-[2px] w-full bg-color-font/10"></div>
			<div class="markdown w-fill mt-4 flex flex-1 flex-col px-[2%] py-2">
				<Content />
			</div>
			<footer
				class="mt-10 flex flex-wrap items-center justify-between gap-2 text-sm opacity-60"
			>
				<span>
					转载请注明出处：
					<a href={canonicalUrl}>{canonicalUrl}</a>
				</span>
				<a
					href={githubEditUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="hover:opacity-100"
				>
					在 GitHub 上编辑此页
				</a>
			</footer>
		</article>
	</div>
</Layout>
