---
import Layout from "../layouts/Layout.astro";
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_NAME } from "../consts";
import SpotlightCard from "@/components/SpotlightCard.astro";

const HOME_TITLE = "Emiya's site";
const HOME_DESCRIPTION = "前端开发者 Emiya 的个人主页";

if (!Astro.site) {
	throw new Error("Missing `site` in astro.config.mjs");
}

const siteUrl = Astro.site.origin;

const personJsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: SITE_AUTHOR.name,
	url: siteUrl,
	jobTitle: "Front-end Developer",
	description: SITE_DESCRIPTION,
	sameAs: ["https://github.com/Emiyaaaaa", "https://x.com/emiya0505"]
};

const websiteJsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: SITE_NAME,
	url: siteUrl,
	inLanguage: "zh-CN",
	description: SITE_DESCRIPTION,
	author: {
		"@type": "Person",
		name: SITE_AUTHOR.name,
		url: siteUrl
	}
};
---

<Layout
	absoluteTitle={HOME_TITLE}
	description={HOME_DESCRIPTION}
	canonical="/"
	ogType="profile"
	ogTitle={HOME_TITLE}
	ogDescription={HOME_DESCRIPTION}
	twitterTitle={HOME_TITLE}
	twitterDescription={HOME_DESCRIPTION}
	jsonLd={[personJsonLd, websiteJsonLd]}
>
	<div class="absolute top-0 left-0 w-screen h-screen pb-15">
		<div class="flex w-full h-full flex-col items-center justify-center">
			<div class="w-4/5 max-w-160">
				<SpotlightCard class="w-full">
					<div class="flex w-full items-start">
						<div
							class="mb-10 space-y-4 font-bold text-2xl lg:text-4xl leading-[1.2]"
						>
							Hello~
							<br />
							I'm Emiya
						</div>
						<img
							alt=""
							class="ml-auto w-10 h-10 shrink-0 rounded"
							src="data:image/jpg;base64,"
						/>
					</div>
					Front-end developer
					<span class="hidden sm:inline"> / previously at </span>
					<div class="mt-2 sm:hidden"></div>
					<span class="inline sm:hidden"> Ex </span>
					<a
						class="tag ml-0.5"
						href="https://realsee.com"
						target="_blank"
						rel="noopener noreferrer"
					>
						<img
							alt="Realsee"
							class="mr-1 inline"
							width="16"
							height="16"
							src="https://realsee.com/favicon.ico"
						/>
						Realsee
					</a><a
						class="tag ml-0.5"
						href="https://ke.com"
						target="_blank"
						rel="noopener noreferrer"
					>
						<img
							alt="贝壳找房"
							class="mr-1 inline"
							width="16"
							height="16"
							src="https://ke.com/favicon.ico"
						/>
						Beike
					</a>
				</SpotlightCard>
				<div class="flex mt-4 leading-none font-medium">
					<div
						class="cursor-pointer border-color-font hover:text-color-font-hover hover:border-color-font/50"
					>
						<a href="/posts">
							<span class="text-[#92fffa]">{"~"}</span>
							<span class="text-[#35BD34]">cd</span>
							<span class="border-b">posts</span>
						</a>
					</div>
					<div class="social-links flex ml-auto gap-4">
						<a target="_blank" href="https://github.com/Emiyaaaaa">Github</a>
						<a target="_blank" href="https://x.com/emiya0505">X</a>
						<a target="_blank" href="/image/wechat.jpg">WeChat</a>
						<a target="_blank" href="mailto:emiya@emiya.com.cn">Email</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	@reference "../styles/global.css";

	.social-links a {
		@apply border-b-2 border-transparent;
	}

	.social-links a:hover {
		@apply border-color-font/50 text-color-font/70;
	}

	.tag {
		@apply inline-flex items-center rounded px-1 py-0.5 text-[0.8em] no-underline align-bottom;
		@apply bg-color-font/10 text-color-font/80;
		@apply hover:text-color-font hover:bg-color-font/20;
	}
</style>
