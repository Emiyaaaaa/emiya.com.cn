---
const iconWidth = 22;
---

<button
	type="button"
	class="fixed right-4 top-4 z-50 inline-flex items-center justify-center rounded-full text-color-font/80"
	data-theme-toggle
>
	<span data-theme-icon="light">
		<svg
			viewBox="0 0 1024 1024"
			xmlns="http://www.w3.org/2000/svg"
			fill="inherit"
			width={iconWidth}
			height={iconWidth}
		>
			<path
				d="M512 810.666667a42.666667 42.666667 0 0 1 42.666667 42.666666v42.666667a42.666667 42.666667 0 0 1-85.333334 0v-42.666667a42.666667 42.666667 0 0 1 42.666667-42.666666z m271.573333-87.466667l30.08 30.08a42.666667 42.666667 0 0 1-60.373333 60.373333l-30.08-30.08a42.666667 42.666667 0 0 1 60.373333-60.373333z m-543.146666 0a42.666667 42.666667 0 0 1 64 56.32l-3.626667 4.053333-30.08 30.08a42.666667 42.666667 0 0 1-64-56.32l3.626667-4.053333zM170.666667 469.333333a42.666667 42.666667 0 0 1 4.906666 85.333334H128a42.666667 42.666667 0 0 1-4.906667-85.333334H170.666667z m725.333333 0a42.666667 42.666667 0 0 1 0 85.333334h-42.666667a42.666667 42.666667 0 0 1 0-85.333334zM210.346667 210.346667a42.666667 42.666667 0 0 1 56.32-3.626667l4.053333 3.626667 30.08 30.08a42.666667 42.666667 0 0 1-56.32 64l-4.053333-3.626667-30.08-30.08a42.666667 42.666667 0 0 1 0-60.373333z m603.306666 0a42.666667 42.666667 0 0 1 0 60.373333l-30.08 30.08a42.666667 42.666667 0 0 1-60.373333-60.373333l30.08-30.08a42.666667 42.666667 0 0 1 60.373333 0zM512 85.333333a42.666667 42.666667 0 0 1 42.666667 42.666667v42.666667a42.666667 42.666667 0 0 1-85.333334 0V128a42.666667 42.666667 0 0 1 42.666667-42.666667zM512 256a256 256 0 1 0 256 256 256 256 0 0 0-256-256z m0 426.666667a170.666667 170.666667 0 1 1 170.666667-170.666667 170.666667 170.666667 0 0 1-170.666667 170.666667z"
			></path>
		</svg>
	</span>
	<span class="hidden" data-theme-icon="dark">
		<svg
			viewBox="0 0 1024 1024"
			xmlns="http://www.w3.org/2000/svg"
			fill="inherit"
			width={iconWidth}
			height={iconWidth}
		>
			<path
				d="M577.066667 128a42.666667 42.666667 0 0 0-47.146667 60.586667 257.92 257.92 0 0 1-341.333333 341.333333A42.666667 42.666667 0 0 0 128 577.066667a386.773333 386.773333 0 1 0 448-448z m56.106666 106.666667A300.8 300.8 0 1 1 234.666667 633.173333a338.773333 338.773333 0 0 0 59.306666 5.12 343.68 343.68 0 0 0 344.32-343.68 338.773333 338.773333 0 0 0-5.12-59.946666z"
			></path>
		</svg>
	</span>
</button>

<script>
	type Theme = "light" | "dark";

	const storageKey = "theme";
	const root = document.documentElement;
	const button = document.querySelector<HTMLButtonElement>(
		"[data-theme-toggle]"
	);
	const iconLight = button?.querySelector<HTMLElement>(
		'[data-theme-icon="light"]'
	);
	const iconDark = button?.querySelector<HTMLElement>(
		'[data-theme-icon="dark"]'
	);

	function setTheme(theme: Theme) {
		root.dataset.theme = theme;
		root.style.colorScheme = theme;

		if (!button || !iconLight || !iconDark) return;

		const isDark = theme === "dark";
		iconLight.classList.toggle("hidden", !isDark);
		iconDark.classList.toggle("hidden", isDark);
	}

	button?.addEventListener("click", () => {
		const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
		localStorage.setItem(storageKey, nextTheme);
		setTheme(nextTheme);
	});
</script>
