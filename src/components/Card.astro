---
import Devider from "./Devider.astro";
import Time from "./Time.astro";

interface Props {
	title: string;
	description?: string;
	tags?: string[];
	created_at?: Date | null;
	class?: string;
}

const { title, description, tags, created_at, class: className } = Astro.props;
---

<article class:list={["overflow-hidden", className]}>
	<div class="relative mb-0.5 flex flex-col justify-center p-6">
		<h2 class="m-0 text-lg font-black tracking-wide">{title}</h2>
		{
			description && (
				<p class="mt-2 line-clamp-2 text-sm opacity-70">{description}</p>
			)
		}
		<slot />
		<Time
			format="MON DD · YYYY"
			class="right-3 mt-1 block text-sm font-semibold tracking-wide opacity-60"
			date={created_at}
		/>
	</div>
</article>
<Devider />
