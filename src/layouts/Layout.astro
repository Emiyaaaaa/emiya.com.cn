---
import "@fontsource/inter/400.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/900.css";
import "../styles/global.css";
import ThemeScript from "../components/ThemeScript.astro";
import ThemeSwitch from "../components/ThemeSwitch.astro";
import Devider from "../components/Devider.astro";
import Icons from "../components/Icons.astro";
import {
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_KEYWORDS,
	SITE_LOCALE,
	SITE_NAME,
	SITE_OG_IMAGE,
	SITE_TITLE_DEFAULT,
	SITE_TITLE_TEMPLATE,
	SITE_URL
} from "../consts";

interface Props {
	title?: string;
	absoluteTitle?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	keywords?: string[];
	ogType?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogUrl?: string;
	publishedTime?: string;
	modifiedTime?: string;
	tags?: string[];
	twitterTitle?: string;
	twitterDescription?: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title,
	absoluteTitle,
	description = SITE_DESCRIPTION,
	canonical = "/",
	robots,
	keywords,
	ogType = "website",
	ogTitle,
	ogDescription,
	ogUrl,
	publishedTime,
	modifiedTime,
	tags,
	twitterTitle,
	twitterDescription,
	jsonLd
} = Astro.props;

const pageTitle = absoluteTitle
	? absoluteTitle
	: title
		? SITE_TITLE_TEMPLATE.replace("%s", title)
		: SITE_TITLE_DEFAULT;

const resolvedOgTitle = ogTitle ?? (title ? pageTitle : SITE_TITLE_DEFAULT);
const resolvedOgDescription = ogDescription ?? description;
const resolvedOgUrl = ogUrl ?? `${SITE_URL}${canonical === "/" ? "" : canonical}`;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDescription = twitterDescription ?? resolvedOgDescription;
const resolvedKeywords = keywords ?? SITE_KEYWORDS;

const jsonLdScripts = jsonLd
	? Array.isArray(jsonLd)
		? jsonLd
		: [jsonLd]
	: [];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ThemeScript />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="application-name" content={SITE_NAME} />
		<meta name="generator" content="Astro" />
		<meta name="keywords" content={resolvedKeywords.join(", ")} />
		<meta name="author" content={SITE_AUTHOR.name} />
		<meta name="creator" content={SITE_AUTHOR.name} />
		<meta name="publisher" content={SITE_AUTHOR.name} />
		<meta name="referrer" content="origin-when-cross-origin" />
		<meta name="category" content="technology" />
		{
			robots && <meta name="robots" content={robots} />
		}
		<link rel="canonical" href={`${SITE_URL}${canonical}`} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${SITE_NAME} RSS Feed`}
			href={`${SITE_URL}/feed.xml`}
		/>
		<link rel="icon" href="/favicon/favicon.ico" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/favicon/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={SITE_LOCALE} />
		<meta property="og:url" content={resolvedOgUrl} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={resolvedOgTitle} />
		<meta property="og:description" content={resolvedOgDescription} />
		<meta property="og:image" content={SITE_OG_IMAGE} />
		<meta property="og:image:width" content="512" />
		<meta property="og:image:height" content="512" />
		<meta property="og:image:alt" content={SITE_NAME} />
		{
			publishedTime && (
				<meta property="article:published_time" content={publishedTime} />
			)
		}
		{
			modifiedTime && (
				<meta property="article:modified_time" content={modifiedTime} />
			)
		}
		{
			tags?.map((tag) => (
				<meta property="article:tag" content={tag} />
			))
		}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={resolvedTwitterTitle} />
		<meta
			name="twitter:description"
			content={resolvedTwitterDescription}
		/>
		<meta name="twitter:creator" content={SITE_AUTHOR.twitter} />
		<meta name="twitter:image" content={SITE_OG_IMAGE} />
		<meta name="format-detection" content="email=no" />
		<meta name="format-detection" content="address=no" />
		<meta name="format-detection" content="telephone=no" />
		<meta
			name="theme-color"
			media="(prefers-color-scheme: light)"
			content="#ffffff"
		/>
		<meta
			name="theme-color"
			media="(prefers-color-scheme: dark)"
			content="#0a0a0a"
		/>
		{
			jsonLdScripts.map((data) => (
				<script
					type="application/ld+json"
					set:html={JSON.stringify(data)}
				/>
			))
		}
		<slot name="head" />
	</head>
	<body class="font-[Inter,sans-serif]">
		<div class="flex h-full w-full flex-col">
			<div class="p-5">
				<div class="flex items-center">
					<a href="/" aria-label="返回首页">
						<div
							class="pointer-events-none select-none font-black opacity-90"
						>
							{"Emiya's Blog"}
						</div>
					</a>
					<nav
						class="ml-auto flex items-center space-x-5 opacity-90"
						aria-label="主导航"
					>
						<a href="/" aria-label="首页">
							<Icons name="home" width={24} />
						</a>
						<a href="/blog" aria-label="博客文章列表">
							<Icons name="article" width={23} />
						</a>
						<Devider class="h-[20px]" v />
						<a
							href="https://github.com/Emiyaaaaa"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="访问 Emiya 的 GitHub"
						>
							<Icons name="github" width={22} />
						</a>
						<ThemeSwitch width={22} />
					</nav>
				</div>
			</div>
			<main class="flex-1">
				<div class="flex-col items-center h-full w-full">
					<div
						class="mx-auto min-h-full w-full max-w-[51rem] overflow-auto"
					>
						<slot />
					</div>
				</div>
			</main>
		</div>
		<script>
			import { inject } from "@vercel/analytics";
			inject();
		</script>
	</body>
</html>
