---
import "../styles/global.css";
import { Font } from "astro:assets";
import ThemeScript from "../components/ThemeScript.astro";
import ThemeSwitch from "../components/ThemeSwitch.astro";
import {
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_KEYWORDS,
	SITE_LOCALE,
	SITE_NAME,
	SITE_TITLE_DEFAULT,
	SITE_TITLE_TEMPLATE
} from "../consts";

interface Props {
	title?: string;
	absoluteTitle?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	keywords?: string[];
	ogType?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogUrl?: string;
	publishedTime?: string;
	modifiedTime?: string;
	tags?: string[];
	twitterTitle?: string;
	twitterDescription?: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title,
	absoluteTitle,
	description = SITE_DESCRIPTION,
	canonical = "/",
	robots,
	keywords,
	ogType = "website",
	ogTitle,
	ogDescription,
	ogUrl,
	publishedTime,
	modifiedTime,
	tags,
	twitterTitle,
	twitterDescription,
	jsonLd
} = Astro.props;

const pageTitle = absoluteTitle
	? absoluteTitle
	: title
		? SITE_TITLE_TEMPLATE.replace("%s", title)
		: SITE_TITLE_DEFAULT;

if (!Astro.site) {
	throw new Error("Missing `site` in astro.config.mjs");
}

const siteUrl = Astro.site.origin;
const canonicalUrl = new URL(canonical, siteUrl).toString();
const resolvedOgTitle = ogTitle ?? (title ? pageTitle : SITE_TITLE_DEFAULT);
const resolvedOgDescription = ogDescription ?? description;
const resolvedOgUrl = ogUrl ?? canonicalUrl;
const resolvedOgImage = new URL(
	"/favicon/android-chrome-512x512.png",
	siteUrl
).toString();
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDescription = twitterDescription ?? resolvedOgDescription;
const resolvedKeywords = keywords ?? SITE_KEYWORDS;
const rssUrl = new URL("/feed.xml", siteUrl).toString();

const jsonLdScripts = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ThemeScript />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="application-name" content={SITE_NAME} />
		<meta name="generator" content="Astro" />
		<meta name="keywords" content={resolvedKeywords.join(", ")} />
		<meta name="author" content={SITE_AUTHOR.name} />
		<meta name="creator" content={SITE_AUTHOR.name} />
		<meta name="publisher" content={SITE_AUTHOR.name} />
		<meta name="referrer" content="origin-when-cross-origin" />
		<meta name="category" content="technology" />
		{robots && <meta name="robots" content={robots} />}
		<link rel="canonical" href={canonicalUrl} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${SITE_NAME} RSS Feed`}
			href={rssUrl}
		/>
		<link rel="icon" href="/favicon/favicon.ico" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/favicon/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={SITE_LOCALE} />
		<meta property="og:url" content={resolvedOgUrl} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={resolvedOgTitle} />
		<meta property="og:description" content={resolvedOgDescription} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta property="og:image:width" content="512" />
		<meta property="og:image:height" content="512" />
		<meta property="og:image:alt" content={SITE_NAME} />
		{
			publishedTime && (
				<meta property="article:published_time" content={publishedTime} />
			)
		}
		{
			modifiedTime && (
				<meta property="article:modified_time" content={modifiedTime} />
			)
		}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={resolvedTwitterTitle} />
		<meta name="twitter:description" content={resolvedTwitterDescription} />
		<meta name="twitter:creator" content={SITE_AUTHOR.twitter} />
		<meta name="twitter:image" content={resolvedOgImage} />
		<meta name="format-detection" content="email=no" />
		<meta name="format-detection" content="address=no" />
		<meta name="format-detection" content="telephone=no" />
		<meta
			name="theme-color"
			media="(prefers-color-scheme: light)"
			content="#ffffff"
		/>
		<meta
			name="theme-color"
			media="(prefers-color-scheme: dark)"
			content="#0a0a0a"
		/>
		{
			jsonLdScripts.map((data) => (
				<script type="application/ld+json" set:html={JSON.stringify(data)} />
			))
		}
		<Font cssVariable="--font-geist" preload />
		<slot name="head" />
	</head>
	<body>
		<ThemeSwitch />
		<div class="flex h-full w-full flex-col">
			<slot />
		</div>
		<script>
			import { inject } from "@vercel/analytics";
			inject();
		</script>
	</body>
</html>
